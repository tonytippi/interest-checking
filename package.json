{
  "name": "interest-checking",
  "version": "1.0.0",
  "description": "Monitor lending/borrowing APR on Aries and Echelon and notify Telegram on significant changes",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "ts-node src/index.ts",
    "dev:once": "RUN_ONCE=true ts-node src/index.ts",
    "test": "echo \"No tests configured\""
  },
  "keywords": [
    "aries",
    "echelon",
    "apr",
    "telegram",
    "aptos"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aptos-labs/ts-sdk": "^6.3.1",
    "@aries-markets/api": "^0.0.11",
    "@aries-markets/tssdk": "^0.0.1",
    "aptos": "^1.22.1",
    "dotenv": "^17.4.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
