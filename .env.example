# Monitored token symbols (comma separated)
TOKENS=USDC,USDT

# Check cadence in minutes
CHECK_INTERVAL_MINUTES=60

# Absolute APR delta threshold to trigger Telegram alert
# 0.001 = 0.10%
APR_CHANGE_THRESHOLD=0.001

# Telegram settings
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Wallet position settings (optional)
# If set, script also fetches principal deposit/borrow amounts on Aries and Echelon.
WALLET_ADDRESS=

# Aries settings
ARIES_RPC_URL=https://fullnode.mainnet.aptoslabs.com/v1
# Optional explicit token mapping if auto symbol matching picks the wrong reserve
# Format: SYMBOL=COIN_ADDRESS,SYMBOL=COIN_ADDRESS
# Example:
# ARIES_TOKEN_MAP=USDC=0x...,USDT=0x...
ARIES_TOKEN_MAP=
# Debug candidates and computed base APRs for Aries token matching
ARIES_DEBUG=false

# Echelon settings
# Default from Echelon SDK mainnet lending module.
ECHELON_LENDING_MODULE_ADDRESS=0xc6bc659f1649553c1a3fa05d9727433dc03843baac29473c817d06d39e7621ba

# Internal
STATE_FILE_PATH=.interest-state.json
RUN_ONCE=false

# Carry report state
CARRY_STATE_FILE_PATH=.carry-state.json

# Carry alert threshold (absolute Delta/h in token units). 0 disables alert.
CARRY_DRIFT_THRESHOLD_PER_HOUR=0
